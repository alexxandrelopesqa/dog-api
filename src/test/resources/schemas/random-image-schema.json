{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "message",
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "const": "success"
    },
    "message": {
      "type": "string",
      "pattern": "^https?://.+"
    }
  },
  "additionalProperties": false
}
